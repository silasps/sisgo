# =============================================================
# SISGO — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite .env.local no git
# =============================================================

# -------------------------------------------------------------
# Supabase (obrigatório)
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# -------------------------------------------------------------
# URL publica da aplicacao (obrigatorio para login OAuth em producao)
# Use o dominio exato da Vercel, sem barra final.
# Exemplo: https://sisgo.vercel.app
# -------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -------------------------------------------------------------
# Brevo (envio de e-mails transacionais — free: 300/dia, 9.000/mês)
# Crie sua conta em brevo.com → SMTP & API → API Keys
# -------------------------------------------------------------
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxx
BREVO_FROM_EMAIL=noreply@sisgomission.com

# -------------------------------------------------------------
# Pagamentos PIX — configure apenas o provedor que sua base utiliza
# O provedor é definido por base nas configurações do Financeiro.
# -------------------------------------------------------------

# Asaas (https://asaas.com)
# ASAAS_ACCESS_TOKEN=
# ASAAS_ENVIRONMENT=sandbox   # "sandbox" ou "production"

# MercadoPago (https://mercadopago.com.br)
# MERCADO_PAGO_ACCESS_TOKEN=

# PagBank / PagSeguro (https://pagbank.com.br)
# PAGBANK_TOKEN=

# -------------------------------------------------------------
# Configuração da URL base (usada para webhooks de pagamento)
# Em produção, defina como a URL pública da aplicação
# -------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000
